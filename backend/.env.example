# Copier ce fichier en ".env" et renseigner les valeurs réelles.

# Environnement Flask : "development" ou "production"
FLASK_ENV=development

# Chaîne de connexion PostgreSQL (Neon)
# Format : postgresql://<user>:<password>@<host>/<database>?sslmode=require&channel_binding=require
DATABASE_URL=

# Origines autorisées pour le frontend (CORS), séparées par des virgules
CORS_ORIGINS=http://localhost:3000

# Port d'écoute local (Render fournit automatiquement sa propre variable PORT)
PORT=5000

# Nombre de résultats de recherche par défaut / maximum
DEFAULT_TOP_K=12
MAX_TOP_K=50

# Taille maximale (Mo) des images envoyées pour la recherche visuelle
MAX_UPLOAD_SIZE_MB=8
